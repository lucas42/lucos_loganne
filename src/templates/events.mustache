<!DOCTYPE html>
<html>
	<head>
		<title>Loganne</title>
		<link href="/style.css" rel="stylesheet">
		<link rel="icon" href="/icon" />
		<link rel="manifest" href="/manifest.json" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="mobile-web-app-capable" content="yes">
	</head>
	<body>

		<lucos-navbar>Loganne</lucos-navbar>
		<nav id="level-filter" aria-label="Filter by level">
			{{#levels}}
			<a href="/view?level={{name}}"{{#active}} aria-current="page"{{/active}}>{{name}}</a>
			{{/levels}}
		</nav>
		<ul id="events">
			{{^events}}
				<li class="loading">Still waiting for events to start logging.  Refresh soon…</li>
			{{/events}}
			{{#events}}
				{{> event}}
			{{/events}}
		</ul>
		<script type='text/javascript' src='/client.js'></script>
	</body>
</html>
