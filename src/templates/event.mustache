			<li data-source="{{source}}" data-webhookstatus="{{webhookStatus}}" data-uuid="{{uuid}}"{{#webhookErrorMessage}} title="{{webhookErrorMessage}}"{{/webhookErrorMessage}}>
				<span class="source" title="{{source}}">{{prettySource}}</span>
				<span class="date" data-date="{{absDate}}" title="{{absDate}}">{{relDate}}</span>
				<span class="human">
				{{#showUrl}}
					<a href="{{url}}" target="_blank">{{humanReadable}}</a>
				{{/showUrl}}
				{{^showUrl}}
					{{humanReadable}}
				{{/showUrl}}
				</span>
				{{#webhookFailed}}
				<form method="post" action="/events/{{uuid}}/retry-webhooks">
					<button type="submit">Retry webhooks</button>
				</form>
				{{/webhookFailed}}
			</li>