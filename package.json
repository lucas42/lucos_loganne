    "start": "node --no-webstorage index.js",
    "build": "webpack"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lucas42/lucos_loganne.git"
  },
  "bugs": {
    "url": "https://github.com/lucas42/lucos_loganne/issues"
  },
  "homepage": "https://github.com/lucas42/lucos_loganne#readme",
  "dependencies": {
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "lucos_aithne_jsclient": "^1.1.0",
    "lucos_navbar": "^2.3.2",
    "lucos_time_component": "^2.1.97",
    "mustache-express": "^1.3.2",
    "uuid": "^14.0.1",
    "webpack-cli": "^7.2.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "supertest": "^7.2.2"
  },
